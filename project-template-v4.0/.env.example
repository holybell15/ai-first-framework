# ============================================================
# [專案名稱] — Environment Variables Example
# ============================================================
# 複製此檔案為 .env（不得 commit .env 到 Git）
# cp .env.example .env
#
# 所有敏感值（密碼、API Key、Secret）必須從這裡取，
# 禁止 hardcode 在程式碼或文件中（V17 Gate 3 驗收要求）
# ============================================================

# ── Application ─────────────────────────────────────────────
APP_NAME=[專案名稱]
APP_ENV=development                 # development | staging | production
APP_PORT=8080
APP_SECRET_KEY=replace-with-strong-secret

# ── Database ─────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=[專案名稱]_db
DB_USER=app_user
DB_PASSWORD=replace-with-db-password
DB_POOL_MIN=2
DB_POOL_MAX=10

# ── Redis / Cache ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ── JWT / Auth ───────────────────────────────────────────────
JWT_SECRET=replace-with-jwt-secret
JWT_EXPIRES_IN=3600                 # seconds
REFRESH_TOKEN_EXPIRES_IN=604800     # 7 days in seconds

# ── Multi-Tenant ─────────────────────────────────────────────
# tenant_id 從 JWT 取得，禁止從 Request Body 傳入
TENANT_HEADER=X-Tenant-ID

# ── Encryption (AES-256-GCM) ─────────────────────────────────
# enc_ 前綴欄位的加密金鑰（生產環境應從 HSM/KMS 取得）
ENCRYPTION_KEY=replace-with-32-byte-hex-key

# ── External APIs ────────────────────────────────────────────
# THIRD_PARTY_API_KEY=replace-with-key
# THIRD_PARTY_API_URL=https://api.example.com

# ── AI / LLM ─────────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# AI_MODEL=claude-sonnet-4-6
# AI_MAX_TOKENS=4096

# ── Cloud Storage ────────────────────────────────────────────
# STORAGE_BUCKET=your-bucket-name
# STORAGE_REGION=us-east-1

# ── Observability ────────────────────────────────────────────
LOG_LEVEL=info                      # debug | info | warn | error
# SENTRY_DSN=https://...@sentry.io/...

# ── Feature Flags ────────────────────────────────────────────
# FF_NEW_FEATURE=false
